{
  "name": "datadog",
  "version": "0.5.0",
  "description": "Use Datadog directly in Cursor. Query logs, metrics, traces, dashboards, and more through natural conversation. Configure your domain and organization with automatic OAuth authentication.",
  "author": {
    "name": "Datadog"
  },
  "repository": "https://github.com/datadog-labs/cursor-plugin.git",
  "keywords": [
    "ai",
    "api",
    "datadog",
    "mcp"
  ],
  "mcpServers": {
    "datadog": {
      "command": "${CURSOR_PLUGIN_ROOT}/bin/core.mjs"
    }
  },
  "hooks": {
    "sessionStart": [
      {
        "matcher": "startup",
        "type": "command",
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/session-start.mjs"
      }
    ]
  }
}
